# StealthPay Backend Environment Variables

# App
APP_SECRET_KEY=your_secret_key_here
DEBUG=False
ALLOWED_ORIGINS=http://localhost:3000,https://hightix3.github.io
ALLOWED_IPS=
IP_RISK_BLOCKLIST=
REQUEST_SIGNATURE_SECRET=
SIGNATURE_TOLERANCE_SECONDS=300
REQUIRE_TLS=true

# Database
DATABASE_URL=sqlite:///./stealthpay.db
# For production use PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost/stealthpay

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14

# Plaid (Bank Linking)
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox
# PLAID_ENV=production

# Stripe (Virtual Card)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Crypto (Web3)
WEB3_PROVIDER_URL=https://mainnet.infura.io/v3/your_infura_key
ETH_NETWORK=mainnet

# Monero
MONERO_RPC_URL=http://127.0.0.1:18081
MONERO_WALLET_RPC_URL=http://127.0.0.1:18082
MONERO_WALLET_PASSWORD=your_wallet_password

# RTP / ACH
RTP_API_KEY=your_rtp_provider_key
ACH_API_KEY=your_ach_provider_key

# Compliance
AML_AMOUNT_THRESHOLD=10000
COLD_STORAGE_THRESHOLD=5000
ENFORCE_KYC=true
ENFORCE_ADMIN_MFA=true

# Email (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_password

